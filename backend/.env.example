# ============================================
# SPIRITUAL AWAKENING APP - BACKEND CONFIG
# Built by: MrHim-Creator from South Africa
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite:./data/app.db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars_generate_new
JWT_EXPIRY=24h

# Paystack Configuration (FREE tier available)
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# Email Configuration (optional, for future)
SENDGRID_API_KEY=your_sendgrid_key_here

# ============================================
# INSTRUCTIONS:
# 1. Copy this file to: backend/.env
# 2. Generate JWT_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Get Paystack keys from: https://dashboard.paystack.com/settings/developer
# 4. NEVER commit .env to git (it's in .gitignore)
# ============================================
