# ============================================
# SPIRITUAL AWAKENING APP - BACKEND CONFIG
# Built by: MrHim-Creator from South Africa
# FREE APP - No payments required
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database Configuration
# Development: SQLite (default)
# Production: PostgreSQL
DB_TYPE=sqlite
DATABASE_URL=postgresql://username:password@localhost:5432/spiritual_awakening

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars_generate_new
JWT_EXPIRY=24h

# Email Configuration (optional, for future)
SENDGRID_API_KEY=your_sendgrid_key_here

# ============================================
# INSTRUCTIONS:
# 1. Copy this file to: backend/.env
# 2. Generate JWT_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. For production, set DB_TYPE=postgres and DATABASE_URL to your PostgreSQL connection string
# 4. NEVER commit .env to git (it's in .gitignore)
# ============================================
